{
  "version": 2,
  "routes": [
    { "src": "/api/leads", "dest": "/api/leads.js" },
    { "src": "/api/admin/login", "dest": "/api/admin/login.js" },
    { "src": "/api/admin/logout", "dest": "/api/admin/logout.js" },
    { "src": "/api/admin/leads(.*)", "dest": "/api/admin/leads.js" },
    { "src": "/api/admin/outreach(.*)", "dest": "/api/admin/outreach.js" },
    { "src": "/health", "dest": "/api/health.js" },
    { "src": "/admin/?$", "dest": "/public/admin.html" },
    {
      "src": "/(communities/[a-z0-9-]+|privacy|terms)/?$",
      "dest": "/public/index.html"
    },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
